---
---
<div class="tarjeta-regalos w-full">
  <div class="bg-white shadow-xl overflow-hidden">
    <div class="px-3 py-6 text-center">

      <div class="flex justify-center mb-2">
        <img src="/iconos/torta.png" alt="Regalos" class="w-10 h-10 object-contain verde-filter" />
      </div>

      <h2 class="font-cormorant text-xl text-[#c8b194] uppercase font-semibold mb-1">Sugerencia de Regalos</h2>

      <div class="flex items-center gap-2 mb-2">
        <div class="flex-1 h-px bg-[#c8b194]"></div>
        <span class="text-[#c8b194] text-[10px]">✦</span>
        <div class="flex-1 h-px bg-[#c8b194]"></div>
      </div>

      <p class="font-cormorant text-sm text-[#4d5441] leading-tight mb-1">El mejor regalo es su presencia.</p>
      <p class="font-cormorant text-xs text-[#4d5441] leading-tight mb-2">Si desean un detalle especial, pueden hacerlo mediante este QR.</p>

      <!-- QR ancho completo -->
      <div class="w-full mb-2 overflow-hidden border border-[#c8b194]/40">
        <img src="/imagenes/qr.png" alt="QR" class="w-full object-contain"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"/>
        <div class="hidden w-full h-24 items-center justify-center bg-[#f5f0e8]">
          <p class="font-cormorant text-xs text-[#c8b194]/60">QR</p>
        </div>
      </div>

      <p class="font-cormorant text-sm text-[#c8b194] font-semibold leading-tight">Balcazar Ribera Gustavo Adolfo</p>

    </div>
  </div>
</div>

<style>
  .verde-filter {
    filter: brightness(0) saturate(100%) invert(29%) sepia(30%) saturate(600%) hue-rotate(115deg) brightness(80%) contrast(90%);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);
  gsap.fromTo(".tarjeta-regalos",
    { opacity: 0, y: 40 },
    { opacity: 1, y: 0, duration: 1, ease: "power3.out",
      scrollTrigger: { trigger: ".tarjeta-regalos", start: "top 90%", toggleActions: "play none none reset" }
    }
  );
</script>

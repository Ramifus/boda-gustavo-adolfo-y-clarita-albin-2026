---
// FotoZoom2.astro - Foto 2 con animación elegante para boda
---

<section
    class="relative w-full h-screen flex flex-col items-center justify-center overflow-hidden"
>
    <!-- Fondo con imagen ESTÁTICA -->
    <div class="absolute inset-0 z-0">
        <img
            id="parallax-image-2"
            src="/imagenes/foto2.webp"
            alt="Fotografía de boda"
            class="w-full h-full object-cover opacity-0"
        />
        <div class="absolute inset-0 bg-black/30 opacity-0" id="overlay-2">
        </div>
    </div>

</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            console.log("📸 Iniciando animaciones de foto...");

            const image = document.querySelector("#parallax-image-2");
            const overlay = document.querySelector("#overlay-2");

            // Estado inicial
            gsap.set(image, { scale: 1.3, opacity: 0 });
            gsap.set(overlay, { opacity: 0 });

            // Animación con ScrollTrigger
            ScrollTrigger.create({
                trigger: "#parallax-image-2",
                start: "top bottom",
                end: "top 20%",

                onEnter: () => {
                    const tl = gsap.timeline();

                    // 1️⃣ Imagen - Zoom suave y elegante
                    tl.to(
                        image,
                        {
                            scale: 1,
                            opacity: 1,
                            duration: 2.5,
                            ease: "power2.out",
                        },
                        0,
                    )

                        // 2️⃣ Overlay - Aparición suave
                        .to(
                            overlay,
                            {
                                opacity: 1,
                                duration: 2,
                                ease: "power1.out",
                            },
                            0.3,
                        );
                },

                onLeaveBack: () => {
                    const tl = gsap.timeline();

                    tl.to(
                            overlay,
                            {
                                opacity: 0,
                                duration: 0.5,
                                ease: "power1.in",
                            },
                            0,
                        )
                        .to(
                            image,
                            {
                                scale: 1.3,
                                opacity: 0,
                                duration: 0.8,
                                ease: "power2.in",
                            },
                            0,
                        );
                },
            });

            console.log("✨ Animación de foto lista!");
        });
    }
</script>

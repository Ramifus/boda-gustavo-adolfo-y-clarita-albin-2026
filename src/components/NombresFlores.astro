        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
      </svg>
      <svg class="w-6 h-6 text-[#c8b194]/65 animate-[chevron-flow_1.8s_ease-in-out_infinite_0.18s]"

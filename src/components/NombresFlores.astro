    <div class="flex flex-col items-center -space-y-2">
      <svg class="w-6 h-6 text-[#c8b194] drop-shadow-[0_1px_4px_rgba(0,0,0,0.5)] animate-[chevron-flow_1.8s_ease-in-out_infinite]"
